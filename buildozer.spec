[app]

title = Flappy Bird
package.name = flappybird
package.domain = io.github.anandcaptain

source.dir = .
source.include_exts = py

version = 1.0.0

requirements = python3,kivy

orientation = portrait
fullscreen = 1

android.api = 33
android.minapi = 21
android.archs = arm64-v8a, armeabi-v7a

[buildozer]

log_level = 2
warn_on_root = 1
